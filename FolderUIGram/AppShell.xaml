<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FolderUIGram.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FolderUIGram"
    Title="FolderUIGram">

    <TabBar x:Name="MainTabBar">
        <Tab Title="Upload" Route="UploadTab">
            <ShellContent ContentTemplate="{DataTemplate local:ActionsPage}" Route="UploadPage" />
        </Tab>
        <Tab Title="Messages" Route="MessagesTab">
            <ShellContent ContentTemplate="{DataTemplate local:MessagesPage}" Route="MessagesPage" />
        </Tab>
        <Tab Title="Settings" Route="SettingsTab">
            <ShellContent ContentTemplate="{DataTemplate local:SettingsPage}" Route="SettingsPage" />
        </Tab>
    </TabBar>

</Shell>
